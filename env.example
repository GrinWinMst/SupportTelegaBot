# ═══════════════════════════════════════════════════════════
# КОНФИГУРАЦИЯ БОТА SUPPORTDAWN
# ═══════════════════════════════════════════════════════════
#
# ИНСТРУКЦИЯ:
# 1. Скопируйте этот файл и назовите его .env
# 2. Замените все значения на реальные
# 3. НЕ ПУБЛИКУЙТЕ файл .env в публичных местах!
#
# ═══════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════
# TELEGRAM BOT
# ═══════════════════════════════════════════════════════════
# Получите токен у @BotFather в Telegram
# Формат: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN=

# ═══════════════════════════════════════════════════════════
# MINECRAFT RCON
# ═══════════════════════════════════════════════════════════
# IP или домен вашего Minecraft сервера
RCON_HOST=localhost

# Порт RCON (по умолчанию 25575)
RCON_PORT=25575

# Пароль RCON из server.properties
RCON_PASSWORD=

# ═══════════════════════════════════════════════════════════
# АДМИНИСТРАТОРЫ И СОТРУДНИКИ
# ═══════════════════════════════════════════════════════════
# Telegram ID администраторов (полный доступ)
# Формат: числа через запятую без пробелов
# Как узнать свой ID: напишите боту @userinfobot
ADMIN_IDS=

# Telegram ID сотрудников поддержки (ограниченный доступ)
# Формат: числа через запятую без пробелов
SUPPORT_STAFF_IDS=

# ═══════════════════════════════════════════════════════════
# БАЗА ДАННЫХ MYSQL
# ═══════════════════════════════════════════════════════════
# Хост MySQL (обычно localhost на виртуальном хостинге)
MYSQL_HOST=localhost

# Порт MySQL (обычно 3306)
MYSQL_PORT=3306

# Имя пользователя MySQL
MYSQL_USER=

# Пароль MySQL
MYSQL_PASSWORD=

# Название базы данных
MYSQL_DATABASE=

# ═══════════════════════════════════════════════════════════
# ПРИМЕР ЗАПОЛНЕНИЯ
# ═══════════════════════════════════════════════════════════
#
# BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz-1234567
# RCON_HOST=play.myserver.com
# RCON_PORT=25575
# RCON_PASSWORD=super_secret_password_123
# ADMIN_IDS=123456789,987654321
# SUPPORT_STAFF_IDS=111222333,444555666
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=u3083568_botuser
# MYSQL_PASSWORD=SecurePassword123
# MYSQL_DATABASE=u3083568_thedawn
#
# ═══════════════════════════════════════════════════════════

